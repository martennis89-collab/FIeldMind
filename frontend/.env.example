# Copy this file to .env and fill in real values.
# .env is gitignored — never commit the real one.
#
# IMPORTANT: CRA/craco bakes REACT_APP_* variables into the JS bundle at
# BUILD time, not runtime. In local dev (docker-compose.yml, hot-reload
# dev server) this .env is read each time craco recompiles, so editing
# and saving is enough. For a production build (docker-compose.prod.yml),
# this value must instead be passed as a Docker build ARG — see that
# compose file's frontend.build.args.

# Must be reachable from the BROWSER on your machine, not from inside
# the Docker network — so localhost:8001 (the published backend port),
# not http://backend:8001.
REACT_APP_BACKEND_URL=http://localhost:8001
