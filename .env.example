# This file is read automatically by `docker compose` (from the same
# directory as docker-compose.yml) for the ${VAR:-default} substitutions
# in the compose files. It's separate from backend/.env and frontend/.env,
# which configure the applications themselves.
#
# Copy this to .env and adjust if you have port conflicts with other
# things running on your machine.

# Default changed from 3000 -> 3001 because another app is already
# using 3000 on this machine.
FRONTEND_PORT=3001

BACKEND_PORT=8001
MONGO_PORT=27017
