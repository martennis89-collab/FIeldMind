# Copy this file to .env and fill in real values.
# .env is gitignored — never commit the real one.

# ---- REQUIRED — app fails to start without these ----

# Inside docker-compose, "mongo" is the service name (Docker's internal DNS).
# For a managed Mongo (Atlas etc.) replace with your real connection string.
MONGO_URL=mongodb://mongo:27017
DB_NAME=fieldmind

# No default on purpose (auth.py reads this with no fallback).
# Generate a real one with: openssl rand -hex 32
JWT_SECRET=changeme-generate-a-real-32-byte-secret

# ---- Optional — defaults shown are what the code falls back to ----

JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=15
REPORT_GEN_LIMIT=20
REPORT_GEN_WINDOW_S=60
ENFORCE_COMPANY_ISOLATION=true

# Comma-separated list of allowed origins for the frontend.
# "*" works for local dev; lock this down for production.
CORS_ORIGINS=http://localhost:3000

# Set to "true" to enable POST /api/seed/init (creates demo
# admin/manager/TM accounts with known passwords). Leave unset/false
# anywhere reachable from the internet.
ENABLE_DEMO_SEED=false

# ---- Optional — required only if you want AI features working ----
# Powers ai.py (visit-note extraction) and expenses_ai.py (receipt OCR)
# via the Anthropic API directly. Without it, those two features fail
# gracefully but everything else in the app works normally.
ANTHROPIC_API_KEY=

# Powers voice-note transcription in routers/visits.py via ElevenLabs
# Scribe. Without it, transcription returns a 503 but note text can
# still be typed manually.
ELEVENLABS_API_KEY=

# ---- Optional — Telegram daily check-in (routers/telegram.py) ----
# Single-user personal automation. Without these, the daily loop and
# webhook both silently no-op.
TELEGRAM_BOT_TOKEN=
# The one chat allowed to log visits — messages from any other chat are ignored.
TELEGRAM_CHAT_ID=
# Which FieldMind user account visits get logged as.
TELEGRAM_USER_EMAIL=
# Random string — must match the secret_token passed to Telegram's setWebhook call.
# Generate with: openssl rand -hex 24
TELEGRAM_WEBHOOK_SECRET=
